{
  "name": "@dbushell/sauropod",
  "version": "0.33.0",
  "tasks": {
    "dev": "deno run --no-lock --unstable-kv --unstable-cron --allow-all mod.ts --dev",
    "prod": "deno run --no-lock --unstable-kv --unstable-cron --allow-all mod.ts --cron --sync"
  },
  "exports": {
    ".": "./mod.ts"
  },
  "imports": {
    "@dbushell/audio-duration": "jsr:@dbushell/audio-duration@^0.6.0",
    "@dbushell/carriageway": "jsr:@dbushell/carriageway@^1.0.1",
    "@dbushell/xml-streamify": "jsr:@dbushell/xml-streamify@^0.6.0",
    "@src/": "./src/",
    "@ssr/dinossr": "jsr:@ssr/dinossr@^0.35.0",
    "@std/assert": "jsr:@std/assert@^1.0.2",
    "@std/crypto": "jsr:@std/crypto@^1.0.2",
    "@std/encoding": "jsr:@std/encoding@^1.0.1",
    "@std/fs": "jsr:@std/fs@^1.0.1",
    "@std/html": "jsr:@std/html@^1.0.1",
    "@std/http": "jsr:@std/http@^1.0.0",
    "@std/log": "jsr:@std/log@^0.224.5",
    "@std/media-types": "jsr:@std/media-types@^1.0.2",
    "@std/path": "jsr:@std/path@^1.0.2",
    "svelte": "npm:svelte@^4.2.18"
  }
}
